---

<section id="work" class="px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <h2 class="mb-4 text-sm font-medium tracking-wider text-accent uppercase">Selected Work</h2>
    <p class="mb-12 text-gray-400">Projects taken from research to production.</p>

    <div class="space-y-8">
      {projects.map(project => (
        <div class="group rounded-2xl border border-border bg-surface p-8 transition-colors hover:border-accent/40">
          <div class="mb-6">
            <span class="mr-3 text-3xl font-bold text-accent/40">{project.number}</span>
            <h3 class="mt-2 text-xl font-bold text-white sm:text-2xl">{project.title}</h3>
            <span class="mt-3 inline-block rounded-full border border-accent/30 bg-accent/10 px-3 py-1 text-xs font-medium text-accent">
              {project.tag}
            </span>
          </div>

          <p class="mb-4 text-xs font-medium tracking-wider text-gray-500 uppercase">{project.context}</p>

          <div class="mb-6 space-y-4">
            <p class="text-sm leading-relaxed text-gray-400">{project.problem}</p>
            <p class="text-sm leading-relaxed text-gray-300">{project.built}</p>
            {project.built2 && (
              <p class="text-sm leading-relaxed text-gray-300">{project.built2}</p>
            )}
          </div>

          <div class="mb-6 rounded-lg border border-accent/20 bg-accent/5 px-5 py-3">
            <p class="text-sm font-medium text-accent-hover">{project.result}</p>
          </div>

          <div class="flex flex-wrap gap-2">
            {project.stack.map(tech => (
              <span class="rounded-md bg-gray-800 px-2.5 py-1 text-xs text-gray-400">
                {tech}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
