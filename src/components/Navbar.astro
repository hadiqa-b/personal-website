---
const links = [
  { label: 'Work', href: '#work' },
  { label: 'Stack', href: '#stack' },
  { label: 'Publication', href: '#publication' },
  { label: 'About', href: '#about' },
  { label: 'Contact', href: '#contact' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-[#282828]/90 backdrop-blur-md">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <a href="#" class="block h-10 w-10 overflow-hidden rounded-full">
      <video src="/logo.mp4" autoplay loop muted playsinline class="h-full w-full object-cover mix-blend-screen"></video>
    </a>

    <button
      id="menu-toggle"
      class="flex flex-col gap-1.5 md:hidden"
      aria-label="Toggle menu"
    >
      <span class="block h-0.5 w-6 bg-gray-300 transition-transform" id="bar1"></span>
      <span class="block h-0.5 w-6 bg-gray-300 transition-opacity" id="bar2"></span>
      <span class="block h-0.5 w-6 bg-gray-300 transition-transform" id="bar3"></span>
    </button>

    <ul class="hidden items-center gap-8 md:flex">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class="text-sm text-gray-400 transition-colors hover:text-gray-100"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div id="mobile-menu" class="hidden border-t border-border md:hidden">
    <ul class="flex flex-col gap-1 px-6 py-4">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class="mobile-link block rounded-lg px-3 py-2 text-sm text-gray-400 transition-colors hover:bg-surface hover:text-gray-100"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    bar1?.classList.toggle('translate-y-[4px]', !isOpen);
    bar1?.classList.toggle('rotate-45', !isOpen);
    bar2?.classList.toggle('opacity-0', !isOpen);
    bar3?.classList.toggle('-translate-y-[4px]', !isOpen);
    bar3?.classList.toggle('-rotate-45', !isOpen);
  });

  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      bar1?.classList.remove('translate-y-[4px]', 'rotate-45');
      bar2?.classList.remove('opacity-0');
      bar3?.classList.remove('-translate-y-[4px]', '-rotate-45');
    });
  });
</script>
